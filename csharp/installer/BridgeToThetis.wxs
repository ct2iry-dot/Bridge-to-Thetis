<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="DXLab - Thetis Bridge"
    Manufacturer="Nuno Lopes CT2IRY"
    Version="7.1.0"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of DXLab - Thetis Bridge is already installed." />

    <Media Id="1" Cabinet="BridgeToThetis.cab" EmbedCab="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <Feature Id="ProductFeature" Title="DXLab - Thetis Bridge" Level="1">
      <ComponentGroupRef Id="PublishFiles" />
      <ComponentRef Id="ApplicationShortcutDesktop" />
      <ComponentRef Id="ApplicationShortcutStartMenu" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="DXLab - Thetis Bridge" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="DXLab - Thetis Bridge" />
    </StandardDirectory>
  </Fragment>

  <!-- Bundle entire publish folder (all DLLs + language subdirs) -->
  <Fragment>
    <ComponentGroup Id="PublishFiles" Directory="INSTALLFOLDER"
                    Source="..\BridgeToThetis\publish">
      <Files Include="**\*" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <Component Id="ApplicationShortcutDesktop" Directory="DesktopFolder"
               Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
      <Shortcut Id="DesktopShortcut"
                Name="DXLab - Thetis Bridge"
                Description="DXLab Suite to Thetis SDR spot bridge"
                Target="[INSTALLFOLDER]BridgeToThetis.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="DesktopFolderRemove" Directory="DesktopFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\CT2IRY\BridgeToThetis"
                     Name="DesktopShortcut"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="ApplicationShortcutStartMenu" Directory="ApplicationProgramsFolder"
               Guid="D4E5F6A7-B8C9-0123-DEFA-234567890123">
      <Shortcut Id="StartMenuShortcut"
                Name="DXLab - Thetis Bridge"
                Description="DXLab Suite to Thetis SDR spot bridge"
                Target="[INSTALLFOLDER]BridgeToThetis.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="ApplicationProgramsFolderRemove"
                    Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\CT2IRY\BridgeToThetis"
                     Name="StartMenuShortcut"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>
