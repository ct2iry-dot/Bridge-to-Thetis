<Window x:Class="BridgeToThetis.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Log — Bridge to Thetis"
        Width="900" Height="550"
        Background="#1E1E1E"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2D2D2D" Margin="0,0,0,2">
            <Button Content="Clear Log" Click="BtnClear_Click"
                    Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555" Margin="4,4,2,4" Padding="8,3"/>
            <Button Content="Clear Spots" Click="BtnClearSpots_Click"
                    Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555" Margin="2,4" Padding="8,3"/>
            <Button Content="Send Test Spot" Click="BtnTestSpot_Click"
                    Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555" Margin="2,4" Padding="8,3"/>
            <Button Content="Reconnect TCI" Click="BtnReconnect_Click"
                    Background="#3C3C3C" Foreground="White"
                    BorderBrush="#555" Margin="2,4" Padding="8,3"/>
            <CheckBox x:Name="ChkAutoScroll" Content="Auto-scroll"
                      Foreground="#CCCCCC" IsChecked="True"
                      VerticalAlignment="Center" Margin="8,0"/>
        </StackPanel>

        <!-- Log output -->
        <RichTextBox x:Name="LogBox"
                     Grid.Row="1"
                     Background="#1E1E1E"
                     FontFamily="Consolas"
                     FontSize="10"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Foreground="#CCCCCC"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"/>
    </Grid>
</Window>
